{
  "name": "point-clear-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only local dashboard for the Point Clear repository. Markdown remains canonical; this app only reads and visualizes it.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "typescript": "^5.7.2",
    "unified": "^11.0.5",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
